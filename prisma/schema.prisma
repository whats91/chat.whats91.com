// ========================================
// WHATS91 CHAT - PRISMA SCHEMA
// ========================================
// Dependency note:
// If you change a main-database model here, also review:
// - src/server/db/mysql.ts
// - src/server/auth/auth-service.ts
// - src/server/db/cloud-api-setup.ts
// - src/server/db/cloud-whatsapp-templates.ts
// - src/server/db/chat-labels.ts
// - src/server/controllers/conversation-controller.ts
// - src/lib/types/chat.ts
// Runtime: MySQL
// DATABASE_URL must point to the main application database.
// ========================================
// IMPORTANT: DATABASE SAFETY POLICY
// ========================================
// This project does NOT use automatic migrations.
// All schema changes must be made manually via phpMyAdmin.
// 
// REMOVED COMMANDS (to prevent data loss):
// - npm run db:push    (would modify schema automatically)
// - npm run db:migrate (would run migrations)
// - npm run db:reset   (would DELETE ALL DATA!)
//
// SAFE COMMANDS:
// - npm run db:generate (generates Prisma Client types)
// - npm run db:studio   (opens database GUI viewer)
// ========================================

generator client {
  provider = "prisma-client-js"
}

// ========================================
// MAIN DATABASE
// ========================================

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========================================
// USER MODEL
// ========================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  phone     String?
  avatar    String?
  authToken String?  @map("auth_token")
  status    String   @default("active")
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  cloudApiSetups CloudApiSetup[]
  contacts       Contact[]

  @@map("users")
}

// ========================================
// CONTACT MODEL
// ========================================

model Contact {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  phone     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  company   String?
  notes     String?
  tags      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, phone])
  @@map("contacts")
}

// ========================================
// CLOUD API SETUP MODEL
// ========================================

model CloudApiSetup {
  id                          Int       @id @default(autoincrement())
  uid                         String    @unique @default(uuid())
  userId                      Int       @map("user_id")
  
  facebookAppId               String?   @map("facebook_app_id")
  whatsappAccessToken         String?   @map("whatsapp_access_token")
  whatsappBusinessAccountId   String?   @map("whatsapp_business_account_id")
  phoneNumber                 String?   @map("phone_number")
  phoneNumberId               String?   @map("phone_number_id")
  
  webhookVerifiedAt           DateTime? @map("webhook_verified_at")
  embeddedSetupDoneAt         DateTime? @map("embedded_setup_done_at")
  
  accessChats                 Boolean   @default(false) @map("access_chats")
  
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cloud_api_setup")
}

// ========================================
// CLOUD API REPORT MODEL
// ========================================

model CloudApiReport {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  messageId    String?   @map("message_id")
  receiverId   String?   @map("receiver_id")
  status       String    @default("pending")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("cloud_api_reports")
}

model ChatLabel {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uid        String   @unique @db.VarChar(255)
  userId     BigInt   @map("user_id") @db.UnsignedBigInt
  phoneNumber String  @map("phone_number") @db.VarChar(32)
  labelName  String   @map("label_name") @db.VarChar(120)
  colorCode  String   @default("#2A7B6E") @map("color_code") @db.VarChar(7)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@unique([userId, phoneNumber, labelName], map: "uniq_chat_labels_user_phone_label")
  @@index([userId], map: "idx_chat_labels_user_id")
  @@index([phoneNumber], map: "idx_chat_labels_phone_number")
  @@map("chat_labels")
}

model CloudWhatsappTemplate {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uid               String?  @db.VarChar(255)
  userId            BigInt   @map("user_id")
  templateName      String?  @map("template_name") @db.VarChar(512)
  phoneNumber       BigInt?  @map("phone_number")
  templateId        String?  @map("template_id") @db.VarChar(45)
  category          String?  @db.VarChar(45)
  language          String?  @default("en") @db.VarChar(45)
  tempData          String?  @map("temp_data") @db.LongText
  status            String   @default("DRAFT")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(0)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  metaTemplateId    String?  @map("meta_template_id") @db.VarChar(255)
  wabaId            String?  @map("waba_id") @db.VarChar(255)
  qualityRating     String?  @default("UNKNOWN") @map("quality_rating")
  rejectionReason   String?  @map("rejection_reason") @db.Text
  metaRawData       String?  @map("meta_raw_data") @db.LongText
  templateMediaUrl  String?  @map("template_media_url") @db.Text
  templateMediaType String?  @default("NONE") @map("template_media_type")
  submittedToMetaAt DateTime? @map("submitted_to_meta_at")
  approvedAt        DateTime? @map("approved_at")
  lastSyncedAt      DateTime? @map("last_synced_at")
  parameterFormat   String   @default("POSITIONAL") @map("parameter_format")
  baseTemplateName  String?  @map("base_template_name") @db.VarChar(512)
  version           Int      @default(1)
  versionedTemplateName String? @map("versioned_template_name") @db.VarChar(512)
  isActiveVersion   Boolean  @default(true) @map("is_active_version")
  previousVersionId BigInt?  @map("previous_version_id") @db.UnsignedBigInt

  @@unique([userId, templateName], map: "unique_user_template_name")
  @@unique([userId, baseTemplateName, version], map: "unique_user_template_version")
  @@index([metaTemplateId], map: "idx_whatsapp_templates_meta_template_id")
  @@index([wabaId], map: "idx_whatsapp_templates_waba_id")
  @@index([status], map: "idx_whatsapp_templates_status")
  @@index([submittedToMetaAt], map: "idx_whatsapp_templates_submitted_to_meta_at")
  @@index([baseTemplateName], map: "idx_base_template_name")
  @@index([version], map: "idx_version")
  @@index([isActiveVersion], map: "idx_is_active_version")
  @@index([userId, baseTemplateName], map: "idx_user_base_template_lookup")
  @@index([previousVersionId], map: "fk_previous_version_id")
  @@index([templateMediaType], map: "idx_template_media_type")
  @@map("cloud_whatsapp_templates")
}

model TeamMember {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uid          String   @unique @db.VarChar(255)
  userId       BigInt   @map("user_id") @db.UnsignedBigInt
  name         String   @db.VarChar(255)
  email        String?  @db.VarChar(255)
  mobileNumber String?  @map("mobile_number") @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([userId], map: "idx_team_members_user_id")
  @@index([email], map: "idx_team_members_email")
  @@index([mobileNumber], map: "idx_team_members_mobile_number")
  @@map("team_members")
}

model TeamMemberLabelAssignment {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  teamMemberId BigInt   @map("team_member_id") @db.UnsignedBigInt
  labelId      BigInt   @map("label_id") @db.UnsignedBigInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@unique([teamMemberId, labelId], map: "uniq_team_member_label_assignments_member_label")
  @@index([teamMemberId], map: "idx_team_member_label_assignments_team_member_id")
  @@index([labelId], map: "idx_team_member_label_assignments_label_id")
  @@map("team_member_label_assignments")
}

// ========================================
// CONVERSATION MODEL
// ========================================

model Conversation {
  id                    Int       @id @default(autoincrement())
  userId                Int       @map("user_id")
  contactPhone          String    @map("contact_phone")
  contactId             Int?      @map("contact_id")
  contactName           String?   @map("contact_name")
  conversationNotes     String?   @map("conversation_notes")
  profileImageWasabiPath String?  @map("profile_image_wasabi_path") @db.VarChar(512)
  whatsappPhoneNumberId String    @map("whatsapp_phone_number_id")
  phoneNumber           String?   @map("phone_number")
  
  lastMessageId         String?   @map("last_message_id")
  lastMessageContent    String?   @map("last_message_content")
  lastMessageType       String?   @map("last_message_type")
  lastMessageAt         DateTime? @map("last_message_at")
  lastMessageDirection  String?   @map("last_message_direction")
  
  unreadCount           Int       @default(0) @map("unread_count")
  totalMessages         Int       @default(0) @map("total_messages")
  
  isArchived            Boolean   @default(false) @map("is_archived")
  isPinned              Boolean   @default(false) @map("is_pinned")
  isMuted               Boolean   @default(false) @map("is_muted")
  isBlocked             Boolean   @default(false) @map("is_blocked")
  status                String    @default("active")
  
  metaData              String?   @map("meta_data")
  
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  messages              ConversationMessage[]
  teamAssignment        ConversationTeamAssignment?

  @@index([userId, contactPhone])
  @@index([userId, lastMessageAt])
  @@map("conversations")
}

model ConversationTeamAssignment {
  id             BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  userId         BigInt       @map("user_id") @db.UnsignedBigInt
  conversationId Int          @map("conversation_id")
  teamMemberId   BigInt       @map("team_member_id") @db.UnsignedBigInt
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamp(0)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId], map: "uniq_conversation_team_assignments_conversation_id")
  @@index([userId], map: "idx_conversation_team_assignments_user_id")
  @@index([teamMemberId], map: "idx_conversation_team_assignments_team_member_id")
  @@map("conversation_team_assignments")
}

// ========================================
// CONVERSATION MESSAGE MODEL
// ========================================

model ConversationMessage {
  id                 Int       @id @default(autoincrement())
  conversationId     Int       @map("conversation_id")
  whatsappMessageId  String    @unique @map("whatsapp_message_id")
  
  fromPhone          String    @map("from_phone")
  toPhone            String    @map("to_phone")
  
  direction          String
  messageType        String    @map("message_type")
  messageContent     String?   @map("message_content")
  
  mediaUrl           String?   @map("media_url")
  mediaMimeType      String?   @map("media_mime_type")
  mediaFilename      String?   @map("media_filename")
  mediaCaption       String?   @map("media_caption")
  
  status             String    @default("pending")
  isRead             Boolean   @default(false) @map("is_read")
  isPinned           Boolean   @default(false) @map("is_pinned")
  isStarred          Boolean   @default(false) @map("is_starred")
  readAt             DateTime? @map("read_at")
  
  repliedToMessageId String?   @map("replied_to_message_id")
  
  interactiveData    String?   @map("interactive_data")
  locationData       String?   @map("location_data")
  contactData        String?   @map("contact_data")
  
  timestamp          DateTime
  
  errorMessage       String?   @map("error_message")
  
  webhookData        String?   @map("webhook_data")
  outgoingPayload    String?   @map("outgoing_payload")
  incomingPayload    String?   @map("incoming_payload")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@index([whatsappMessageId])
  @@map("conversation_messages")
}

model ConversationMessageHistory {
  id                Int      @id @default(autoincrement()) @db.UnsignedInt
  whatsappMessageId String   @map("whatsapp_message_id") @db.VarChar(255)
  payload           Json
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([whatsappMessageId], map: "idx_cmh_whatsapp_message_id")
  @@index([createdAt], map: "idx_cmh_created_at")
  @@map("conversation_message_history")
}
