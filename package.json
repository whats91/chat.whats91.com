{
  "name": "whats91-chat",
  "version": "1.0.0",
  "private": true,
  "description": "Whats91 Chat - Multi-tenant WhatsApp Business Platform",
  "main": ".next/standalone/server.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && cp version.txt .next/standalone/ && cp package.json .next/standalone/",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "start:env": "node scripts/start-with-env.js",
    "postinstall": "node scripts/copy-opus-media-recorder-assets.js",
    "copy:voice-recorder-assets": "node scripts/copy-opus-media-recorder-assets.js",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production",
    "pm2:logs": "pm2 logs whats91-chat",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "deploy": "npm run build && pm2 restart ecosystem.config.js --env production",
    "deploy:fresh": "npm install && npm run build && pm2 restart ecosystem.config.js --env production",
    "version:bump": "node scripts/auto-version.js",
    "version:bump:patch": "node scripts/auto-version.js patch",
    "version:bump:minor": "node scripts/auto-version.js minor",
    "version:bump:major": "node scripts/auto-version.js major",
    "git:commit": "bash scripts/git-commit.sh",
    "git:push": "bash scripts/git-push.sh",
    "deploy:server": "node scripts/deploy.js"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
